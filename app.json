{
  "expo": {
    "name": "Internify",
    "slug": "app-pasantias",
    "scheme": "app-pasantias",
    "version": "1.0.0",
    "userInterfaceStyle": "automatic",
    "orientation": "portrait",
    "icon": "./src/assets/images/InternifyV4.png",
    "ios": {
      "associatedDomains": [
        "applinks:internify.institute"
      ]
    },
    "splash": {
      "image": "./src/assets/images/InternifyV4NoLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#3B44F6"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-font",
      "expo-asset",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/images/InternifyV4NoLogo.png",
          "color": "#ffffff"
        }
      ]
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/InternifyV4NoLogo.png",
        "backgroundColor": "#3D3DC8"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "internify.institute",
              "pathPrefix": "/vacancies"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "package": "com.uni.internify",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./src/assets/images/InternifyV4.png"
    },
    "extra": {
      "eas": {
        "projectId": "57f34094-4431-4bf8-a130-e6f3cf7666c6"
      }
    },
    "owner": "cybermedina"
  }
}