{
  "expo": {
    "name": "app-pasantias",
    "slug": "app-pasantias",
    "scheme": "app-pasantias",
    "version": "1.0.0",
    "userInterfaceStyle": "automatic",
    "orientation": "portrait",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-font",
      "expo-asset",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/images/uni-logo.png",
          "color": "#ffffff"
        }
      ]
    ],
    "android": {
    "package": "com.uni.internify",
    "googleServicesFile": "./google-services.json"
  },
    "extra": {
      "eas": {
        "projectId": "57f34094-4431-4bf8-a130-e6f3cf7666c6"
      }
    },
    "owner": "cybermedina"
  }
}
